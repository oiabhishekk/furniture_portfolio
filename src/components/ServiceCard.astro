---
import type { ServiceDetail } from '@/config/services';
import { DoorClosed, Layers, BedDouble, LayoutGrid, Armchair, Hammer, Paintbrush, Wrench, ArrowRight } from '@lucide/astro';

interface Props {
  service: ServiceDetail;
  lang: 'en' | 'hi';
}

const { service, lang } = Astro.props;

// Monospace index eyebrows
const serviceIndices: Record<string, string> = {
  'doors': '01 // CUSTOM DOORS',
  'wardrobes': '02 // modular wardrobes',
  'beds': '03 // HYDRAULIC BEDS',
  'cabinets': '04 // CABINETS & TV UNITS',
  'furniture': '05 // SOLID WOOD FURNITURE',
  'concrete-cornice': '06 // EXTERIOR MOLDINGS',
  'interiors': '07 // COMPLETE INTERIORS',
  'carpentry-renovation': '08 // REPAIRS & RESTORATION'
};

const getIcon = (slug: string) => {
  switch (slug) {
    case 'doors':
      return DoorClosed;
    case 'wardrobes':
      return Layers;
    case 'beds':
      return BedDouble;
    case 'cabinets':
      return LayoutGrid;
    case 'furniture':
      return Armchair;
    case 'concrete-cornice':
      return Hammer;
    case 'interiors':
      return Paintbrush;
    case 'carpentry-renovation':
    default:
      return Wrench;
  }
};

const IconComponent = getIcon(service.slug);
const detailUrl = lang === 'hi' ? `/hi/services/${service.slug}` : `/services/${service.slug}`;
---

<div class="bg-white text-walnut p-8 rounded-2xl border border-hairline hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between h-full group">
  
  <div class="space-y-4">
    <!-- Clean gold ocher outline icon -->
    <div class="w-11 h-11 rounded-lg border border-gold flex items-center justify-center text-gold bg-canvas-soft">
      <IconComponent class="w-5 h-5" />
    </div>

    <!-- Category tag -->
    <span class="font-mono text-[9px] uppercase tracking-wider text-gold font-bold block pt-2">
      {serviceIndices[service.slug] || '00 // WORK'}
    </span>

    <!-- Title (Space Grotesk display) -->
    <h3 class="text-lg font-serif font-bold text-walnut leading-tight font-serif">{service.title}</h3>
    
    <!-- Description -->
    <p class="text-xs text-wood leading-relaxed font-sans font-light line-clamp-3">
      {service.description}
    </p>

    <!-- Subservices bullets list -->
    <div class="pt-4 border-t border-hairline/50">
      <ul class="space-y-1.5">
        {service.subservices.slice(0, 3).map((sub) => (
          <li class="flex items-center space-x-2 text-xs text-wood font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
            <span class="truncate font-sans font-light">{sub}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Read details Link -->
  <div class="pt-6 border-t border-hairline/50 mt-6">
    <a
      href={detailUrl}
      class="inline-flex items-center space-x-1.5 font-mono text-[10px] uppercase font-bold text-gold hover:text-gold-hover tracking-widest"
    >
      <span>{lang === 'hi' ? 'जानकारी देखें' : 'Explore Category'}</span>
      <ArrowRight class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" />
    </a>
  </div>

</div>
