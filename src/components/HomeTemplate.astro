<script>
  function initFaqs() {
    const triggers = document.querySelectorAll('.faq-trigger');
    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const container = trigger.closest('.rounded-xl');
        const content = trigger.nextElementSibling as HTMLElement;
        const icon = trigger.querySelector('.faq-icon') as HTMLElement;
        if (!container || !content) return;

        const expanded = trigger.getAttribute('aria-expanded') === 'true';

        // Close all other panels and reset styling
        document.querySelectorAll('.faq-trigger').forEach((otherTrigger) => {
          if (otherTrigger !== trigger) {
            otherTrigger.setAttribute('aria-expanded', 'false');
            const otherContainer = otherTrigger.closest('.rounded-xl');
            const otherContent = otherTrigger.nextElementSibling as HTMLElement;
            const otherIcon = otherTrigger.querySelector('.faq-icon') as HTMLElement;
            
            if (otherContainer) {
              otherContainer.className = 'rounded-xl overflow-hidden border border-hairline transition-all duration-300 bg-[#F4EFE6] text-walnut hover:bg-canvas-soft-2/80';
            }
            if (otherContent) otherContent.classList.add('hidden');
            if (otherIcon) {
              otherIcon.classList.remove('rotate-180', 'text-white');
              otherIcon.classList.add('text-wood');
            }
          }
        });

        // Toggle current panel
        trigger.setAttribute('aria-expanded', (!expanded).toString());
        if (!expanded) {
          // Make active ocher-gold style
          container.className = 'rounded-xl overflow-hidden border border-gold bg-gold text-white shadow transition-all duration-300';
          content.classList.remove('hidden');
          if (icon) {
            icon.classList.add('rotate-180', 'text-white');
            icon.classList.remove('text-wood');
          }
        } else {
          // Make inactive gray style
          container.className = 'rounded-xl overflow-hidden border border-hairline bg-[#F4EFE6] text-walnut transition-all duration-300';
          content.classList.add('hidden');
          if (icon) {
            icon.classList.remove('rotate-180', 'text-white');
            icon.classList.add('text-wood');
          }
        }
      });
    });
  }

  // Load handler
  initFaqs();
  document.addEventListener('astro:page-load', initFaqs);
</script>
