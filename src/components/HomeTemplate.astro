            const active = idx === 0;
            return (
              <div class={`rounded-xl overflow-hidden border border-hairline transition-all duration-300 ${
                active 
                  ? 'bg-gold text-white border-gold shadow' 
                  : 'bg-[#F4EFE6] text-walnut hover:bg-canvas-soft-2/80'
              }`}>
                <button
                  class="faq-trigger w-full flex items-center justify-between p-5 text-left focus:outline-none cursor-pointer"
                  aria-expanded={active ? "true" : "false"}
                >
                  <span class="font-bold text-xs sm:text-sm font-sans">{faq.q}</span>
                  <ChevronDown class={`w-4 h-4 shrink-0 transition-transform duration-300 faq-icon ${active ? 'rotate-180 text-white' : 'text-wood'}`} />
                </button>
                <div class={`faq-content p-5 pt-0 text-xs sm:text-sm leading-relaxed font-sans font-light ${active ? 'block' : 'hidden'}`}>
                  <p class="border-t border-white/10 dark:border-black/5 pt-3 leading-relaxed">{faq.a}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>

    </div>
  </section>

