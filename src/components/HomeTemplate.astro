---
import Layout from '../layouts/Layout.astro';
import ServiceCard from './ServiceCard.astro';
import { servicesData } from '@/config/services';
import { projectsData } from '../data/projects';
import { useTranslations } from '../data/translations';
import { Phone, MessageCircle, ArrowRight, Check, ChevronDown, Star, Compass, ShieldCheck, Hammer, Layers, Disc, PenTool, Home, Gift, Play, Mail, FileText } from '@lucide/astro';
import { BUSINESS } from '@/config/business';
import { CONTACT } from '@/config/contact';
import { HERO } from '@/config/hero';
import { STATS } from '@/config/stats';
import { TESTIMONIALS } from '@/config/testimonials';
import { SOCIAL } from '@/config/social';

interface Props {
  lang: 'en' | 'hi';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get services & projects
const services = Object.values(servicesData).map(s => s[lang]);
const featuredProjects = projectsData.slice(0, 4); // Fetch 4 projects for the vertical cards grid

const phoneNo = CONTACT.phone;
const whatsappLink = `https://wa.me/${CONTACT.whatsapp.replace('+', '')}?text=${encodeURIComponent(
  lang === 'hi'
    ? 'नमस्ते संतोष जी, मुझे घर के लिए लकड़ी का कस्टम काम (फर्नीचर/दरवाजा) करवाना है।'
    : 'Hello Santosh Ji, I am looking for custom woodwork/furniture services in Patna.'
)}`;

// Testimonials (from testimonials config)
const testimonials = TESTIMONIALS.map(t => ({
  name: t.name[lang],
  role: t.role[lang],
  text: t.text[lang],
  stars: t.stars,
  avatar: t.image
}));

// FAQs (from screenshots layouts)
const faqs = [
  {
    index: '01',
    q: lang === 'hi' ? 'क्या आप साइट पर नाप लेने और चर्चा के लिए पटना में कहीं भी आ सकते हैं?' : 'Do you visit locations inside Patna for measurements?',
    a: lang === 'hi'
      ? 'हाँ, संतोष शर्मा जी स्वयं पटना और उसके आसपास (दानापुर, कंकड़बाग, बेली रोड, बोरिंग रोड, अनीसाबाद, आदि) में आपकी सुविधानुसार साइट पर आकर फ्री नाप और एस्टीमेट प्रदान करते हैं।'
      : 'Yes! Santosh Sharma personally visits your location anywhere in Patna and nearby local regions (Kankarbagh, Boring Road, Bailey Road, Danapur, etc.) at your convenience for space verification, completely free of charge.'
  },
  {
    index: '02',
    q: lang === 'hi' ? 'फर्नीचर के काम के लिए आप कौन सी लकड़ी का उपयोग करते हैं?' : 'What types of wood do you use for custom furniture?',
    a: lang === 'hi'
      ? 'हम ग्राहक की पसंद और बजट के अनुसार 100% असली पक्की सागवान (Teak Wood), साल (Sal Wood), महोगनी, और मरीन ग्रेड प्लाईवुड (BWR/BWP) का उपयोग करते हैं जो दीमक और नमी से सुरक्षित रहती है।'
      : 'We use high-grade seasoned Teak wood (Sagwan), Sal wood, Mahogany, and commercial/waterproof marine-grade plywood (BWR/BWP) depending on your requirements and budget. All woods are treated for moisture and termites.'
  },
  {
    index: '03',
    q: lang === 'hi' ? 'कस्टम फर्नीचर बनाने में कितना समय लगता है?' : 'How long does it take to manufacture and install custom wardrobes?',
    a: lang === 'hi'
      ? 'काम के आकार के अनुसार समय बदलता है। साधारणतया एक सामान्य वार्डरोब या डबल बेड को 7 से 12 दिनों के भीतर तैयार कर आपके घर पर फिट कर दिया जाता है।'
      : 'Depending on the volume of work, a standard sliding wardrobe or a custom bed takes about 7 to 12 days to manufacture and install at your site.'
  },
  {
    index: '04',
    q: lang === 'hi' ? 'क्या आप पुराने फर्नीचर की मरम्मत या री-पॉलिशिंग का काम भी करते हैं?' : 'Do you undertake old furniture repair or re-polishing work?',
    a: lang === 'hi'
      ? 'हाँ, हम पुराने मूल्यवान फर्नीचर की मरम्मत, हार्डवेयर अपग्रेड, मेलामाइन या पीयू पॉलिशिंग का काम भी करते हैं जिससे आपका पुराना फर्नीचर बिल्कुल नया जैसा दिखने लगता है।'
      : 'Yes, we provide premium repair services, hardware replacements (hinges, locks, slides), and high-end Melamine or PU wood re-polishing to restore your old furniture to brand new conditions.'
  }
];

const canonicalPath = lang === 'hi' ? '/hi' : '';
---

<Layout
  title={lang === 'hi' ? 'पटना में नंबर 1 बढ़ई और कस्टम फर्नीचर निर्माता' : 'Best Custom Carpenter & Modular Furniture Maker in Patna'}
  description={lang === 'hi' 
    ? 'संतोष शर्मा बढ़ई (पटना फर्नीचर) - सागवान लकड़ी के दरवाजे, अलमारी, मॉड्यूलर किचन और कंक्रीट कॉर्निस डिज़ाइन के विशेषज्ञ। 100% भरोसेमंद कारीगरी।'
    : 'Santosh Sharma Carpenter offers premium custom woodwork, sliding wardrobes, designer doors, beds, and concrete exterior cornice molds in Patna. Free site visits.'}
  lang={lang}
  canonicalPath={canonicalPath}
>
  
  <!-- SECTION 1: HERO SECTION (Split-layout Replicating Screenshot 2026-07-01 203445.png) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center min-h-[75vh]">
      
      <!-- Left side: Text Stack -->
      <div class="lg:col-span-6 space-y-6 text-left">
        <!-- Subtitle eyebrow -->
        <span class="text-gold font-serif text-xs font-bold uppercase tracking-widest block">
          {HERO.eyebrow[lang]}
        </span>

        <!-- Headline (Space Grotesk, sentence-case, dot terminated) -->
        <h1 class="text-4xl sm:text-6xl font-serif font-medium tracking-tight text-walnut leading-[1.08]">
          {HERO.title[lang]}
        </h1>

        <!-- Short Description -->
        <p class="text-sm sm:text-base text-wood leading-relaxed font-sans font-light max-w-xl">
          {HERO.description[lang]}
        </p>

        <!-- Solid Ocher Buttons -->
        <div class="flex flex-wrap items-center gap-3.5 pt-4">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            <span>{HERO.cta.primary[lang]}</span>
            <ArrowRight class="w-4 h-4" />
          </a>
          <a
            href={`tel:${phoneNo}`}
            class="btn-secondary"
          >
            <Phone class="w-4 h-4 text-gold" />
            <span>{HERO.cta.secondary[lang]}</span>
          </a>
        </div>

        <!-- Social Icons in Gold (Screenshot bottom-left) -->
        <div class="pt-6 flex items-center space-x-5 text-gold text-xs font-mono">
          <span class="text-wood/50 uppercase tracking-widest text-[9px]">Follow //</span>
          <a href={SOCIAL.facebook} class="hover:text-walnut transition-colors">FB</a>
          <a href={SOCIAL.twitter} class="hover:text-walnut transition-colors">TW</a>
          <a href={SOCIAL.youtube} class="hover:text-walnut transition-colors">YT</a>
          <a href={SOCIAL.linkedin} class="hover:text-walnut transition-colors">LN</a>
        </div>
      </div>

      <!-- Right side: Woodwork Measuring image with floating contact card -->
      <div class="lg:col-span-6 relative">
        <div class="rounded-3xl overflow-hidden shadow-xl border border-hairline relative aspect-[4/3] sm:aspect-square lg:aspect-[4/3]">
          <img
            src="/images/references/furniture/woodwork-measuring.jpg"
            alt="Carpenter measuring wooden panels"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/25 to-transparent"></div>
          
          <!-- Floating contact card (Screenshot lower left corner on image) -->
          <div class="absolute bottom-6 left-6 bg-white/95 p-4 rounded-xl shadow-lg border border-hairline text-left">
            <span class="text-[9px] font-mono text-gold uppercase tracking-wider block">Direct Estimate Call</span>
            <span class="text-sm font-bold text-walnut block mt-0.5">{phoneNo}</span>
            <span class="text-[9px] text-wood/60 block">patnafurniture.in</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- SECTION 2: HORIZONTAL FEATURES BAR (Below Hero Replicating Screenshot 2026-07-01 203516.png) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 border-y border-hairline py-10 bg-white/50">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Feature 1: Years Experience -->
      <div class="flex items-start space-x-4">
        <div class="w-12 h-12 rounded-lg border border-gold flex items-center justify-center text-gold shrink-0">
          <Compass class="w-5 h-5" />
        </div>
        <div class="space-y-1">
          <h3 class="text-sm font-bold text-walnut font-sans">Years Experience</h3>
          <p class="text-xs text-wood font-light leading-relaxed">
            {lang === 'hi' ? '३० से अधिक वर्षों का विश्वसनीय लकड़ी काम का अनुभव।' : 'Over 30 years of custom craftsmanship in Bihar.'}
          </p>
        </div>
      </div>

      <!-- Feature 2: Premium Woods -->
      <div class="flex items-start space-x-4">
        <div class="w-12 h-12 rounded-lg border border-gold flex items-center justify-center text-gold shrink-0">
          <Layers class="w-5 h-5" />
        </div>
        <div class="space-y-1">
          <h3 class="text-sm font-bold text-walnut font-sans">Premium Woods</h3>
          <p class="text-xs text-wood font-light leading-relaxed">
            {lang === 'hi' ? 'पक्के असली सागवान और वाटरप्रूफ प्लाईवुड का उपयोग।' : 'Seasoned Teak and termite-safe waterproof ply core.'}
          </p>
        </div>
      </div>

      <!-- Feature 3: Quality Product -->
      <div class="flex items-start space-x-4">
        <div class="w-12 h-12 rounded-lg border border-gold flex items-center justify-center text-gold shrink-0">
          <Disc class="w-5 h-5" />
        </div>
        <div class="space-y-1">
          <h3 class="text-sm font-bold text-walnut font-sans">Quality Product</h3>
          <p class="text-xs text-wood font-light leading-relaxed">
            {lang === 'hi' ? 'अंतिम स्पर्श में उच्च-श्रेणी की चमक और चिकनाई।' : 'Fine precision joint finish with PU spray coatings.'}
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- SECTION 3: ABOUT SECTION (Double Offset Image Replicating Screenshot 2026-07-01 203516.png) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      
      <!-- Left side: Offset Double Image grid -->
      <div class="lg:col-span-6 grid grid-cols-12 gap-4 items-end relative">
        <div class="col-span-7 rounded-2xl overflow-hidden shadow border border-hairline">
          <img
            src="/images/references/furniture/carpenter-assembling-joints.png"
            alt="Woodworker assembling joints"
            class="w-full h-[320px] object-cover"
          />
        </div>
        <div class="col-span-5 rounded-2xl overflow-hidden shadow border border-hairline self-start mt-12">
          <img
            src="/images/references/furniture/mesa.jpg"
            alt="Walnut console cabinet drawer"
            class="w-full h-[220px] object-cover"
          />
        </div>
      </div>

      <!-- Right side: About Text Stack -->
      <div class="lg:col-span-6 space-y-6">
        <span class="text-gold font-serif text-xs font-bold uppercase tracking-widest block">
          ABOUT SANTOSH SHARMA
        </span>
        <h2 class="text-3xl sm:text-4xl font-serif font-medium text-walnut leading-tight">
          Custom Wood Works for Your Custom Tastes.
        </h2>
        <p class="text-sm sm:text-base text-wood leading-relaxed font-sans font-light">
          {lang === 'hi'
            ? 'संतोष शर्मा कारपेंटर पटना का एक विश्वसनीय नाम है, जहाँ हम बिना किसी बाहरी मार्जिन के सीधे आपके घर आकर अलमारी, पलंग और दरवाजे तैयार करते हैं। हम गुणवत्ता में कोई समझौता नहीं करते।'
            : 'We provide hand-sanded Teak doors, custom sliding wardrobes, modular television cabinets, and designer beds. Everything is measured, detailed, and finished at your site to fit your custom layout.'}
        </p>

        <!-- Stats numbers row -->
        <div class="grid grid-cols-2 gap-6 pt-4 border-t border-hairline">
          <div class="space-y-1">
            <span class="text-3xl sm:text-4xl font-serif font-semibold text-walnut">{STATS.completedProjects.number}</span>
            <p class="text-xs text-wood uppercase tracking-wider font-mono">{STATS.completedProjects.label[lang]}</p>
          </div>
          <div class="space-y-1">
            <span class="text-3xl sm:text-4xl font-serif font-semibold text-walnut">{STATS.experience.number}</span>
            <p class="text-xs text-wood uppercase tracking-wider font-mono">{STATS.experience.label[lang]}</p>
          </div>
        </div>

        <a
          href={lang === 'hi' ? '/hi/about' : '/about'}
          class="btn-primary mt-4"
        >
          <span>{lang === 'hi' ? 'अधिक जानें' : 'Learn More'}</span>
          <ArrowRight class="w-4 h-4" />
        </a>
      </div>

    </div>
  </section>

  <!-- SECTION 4: SERVICES SECTION (Dark background strip + 6 white cards Replicating Screenshot 2026-07-01 203552.png) -->
  <section id="services" class="bg-walnut text-white py-24 relative overflow-hidden">
    <!-- Curved wood slats decorative background representation -->
    <div class="absolute inset-0 bg-[#251b14] opacity-40 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-16">
      
      <!-- Center text header -->
      <div class="text-center max-w-3xl mx-auto space-y-3">
        <span class="text-gold font-serif text-xs font-bold uppercase tracking-widest block">
          OUR SERVICES
        </span>
        <h2 class="text-3xl sm:text-5xl font-serif font-medium text-white leading-tight">
          We Craft What You Imagine.
        </h2>
      </div>

      <!-- Grid of 6 white service cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.slice(0, 6).map((service) => (
          <div class="bg-white text-walnut p-8 rounded-2xl shadow-sm border border-hairline flex flex-col justify-between h-full hover:-translate-y-1 transition-all duration-300 group">
            <div class="space-y-4">
              <!-- Gold line icon -->
              <div class="w-10 h-10 rounded bg-gold/5 flex items-center justify-center text-gold">
                <Hammer class="w-5 h-5" />
              </div>
              <h3 class="text-lg font-bold text-walnut font-sans">{service.title}</h3>
              <p class="text-xs text-wood leading-relaxed font-sans font-light line-clamp-3">
                {service.description}
              </p>
            </div>
            
            <a
              href={lang === 'hi' ? `/hi/services/${service.slug}` : `/services/${service.slug}`}
              class="inline-flex items-center space-x-1.5 font-mono text-[10px] uppercase font-bold text-gold hover:text-gold-hover pt-6 tracking-widest"
            >
              <span>{lang === 'hi' ? 'विवरण पढ़ें' : 'Read More'}</span>
              <ArrowRight class="w-3.5 h-3.5" />
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- SECTION 5: WHY CHOOSE US SECTION (Screenshot 2026-07-01 203614.png) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      
      <!-- Left side: text checklist -->
      <div class="lg:col-span-6 space-y-8">
        <div class="space-y-3">
          <span class="text-gold font-serif text-xs font-bold uppercase tracking-widest block">
            WHY CHOOSE US
          </span>
          <h2 class="text-3xl sm:text-4xl font-serif font-medium text-walnut leading-tight">
            Custom Wood Works for Your Custom Tastes.
          </h2>
        </div>

        <div class="space-y-6">
          
          <!-- Item 1: Years Experience -->
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 rounded-full border border-gold flex items-center justify-center text-gold shrink-0 mt-1">
              <Compass class="w-4 h-4" />
            </div>
            <div class="space-y-1">
              <h3 class="text-base font-bold text-walnut">Years Experience</h3>
              <p class="text-xs text-wood leading-relaxed font-sans font-light">
                {lang === 'hi' ? '३०+ वर्षों से पटना में बेहतरीन लकड़ी के इंटीरियर्स का निर्माण कार्य।' : 'Over three decades of architectural carpentry blueprints across Bihar.'}
              </p>
            </div>
          </div>

          <!-- Item 2: Professional Staffs -->
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 rounded-full border border-gold flex items-center justify-center text-gold shrink-0 mt-1">
              <Star class="w-4 h-4" />
            </div>
            <div class="space-y-1">
              <h3 class="text-base font-bold text-walnut">Professional Staffs</h3>
              <p class="text-xs text-wood leading-relaxed font-sans font-light">
                {lang === 'hi' ? 'अनुभवी पॉलिशर्स और फिटिंग कारीगरों की हमारी इन-हाउस टीम।' : 'Highly trained local team for accurate measurements and finishings.'}
              </p>
            </div>
          </div>

          <!-- Item 3: Affordable Price -->
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 rounded-full border border-gold flex items-center justify-center text-gold shrink-0 mt-1">
              <ShieldCheck class="w-4 h-4" />
            </div>
            <div class="space-y-1">
              <h3 class="text-base font-bold text-walnut">Affordable Price</h3>
              <p class="text-xs text-wood leading-relaxed font-sans font-light">
                {lang === 'hi' ? 'बिना शोरूम मार्जिन के सीधे बढ़ई की बचत दरें।' : 'Direct-to-carpenter pricing saving you 30-40% showroom commissions.'}
              </p>
            </div>
          </div>

        </div>
      </div>

      <!-- Right side: spotlight image -->
      <div class="lg:col-span-6">
        <div class="rounded-3xl overflow-hidden shadow-lg border border-hairline aspect-[4/3] sm:aspect-square lg:aspect-[4/3]">
          <img
            src="/images/references/furniture/carpenter-spotlight-measuring.png"
            alt="Carpenter measuring wood under spotlight"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- SECTION 6: OUR PROCESS TIMELINE (Horizontal steps Replicating Screenshot 2026-07-01 203745.png) -->
  <section class="border-y border-hairline py-24 bg-white/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      
      <div class="text-center max-w-3xl mx-auto space-y-3">
        <span class="text-gold font-serif text-xs font-bold uppercase tracking-widest block">
          OUR PROCESS
        </span>
        <h2 class="text-3xl sm:text-4xl font-serif font-medium text-walnut leading-tight">
          We Shape Wood Like No One Else.
        </h2>
      </div>

      <!-- 4 Horizontal timeline steps with outline boxes -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
        
        <!-- Step 1 -->
        <div class="space-y-4 text-center">
          <div class="w-14 h-14 rounded bg-white border border-gold flex items-center justify-center text-gold mx-auto shadow-sm">
            <PenTool class="w-5 h-5" />
          </div>
          <div class="space-y-1">
            <h3 class="text-base font-bold text-walnut font-serif">01. Select Design</h3>
            <p class="text-xs text-wood leading-relaxed font-sans font-light">
              {lang === 'hi' ? 'डिज़ाइन चुनें या अपनी पसंद साझा करें।' : 'Discuss wardrobe or bed models with my father.'}
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="space-y-4 text-center">
          <div class="w-14 h-14 rounded bg-white border border-gold flex items-center justify-center text-gold mx-auto shadow-sm">
            <Home class="w-5 h-5" />
          </div>
          <div class="space-y-1">
            <h3 class="text-base font-bold text-walnut font-serif">02. Wood Selection</h3>
            <p class="text-xs text-wood leading-relaxed font-sans font-light">
              {lang === 'hi' ? 'असली सागवान लकड़ी और वाटरप्रूफ प्लाई चयन।' : 'Select Teak, Sal wood or waterproof BWR boards.'}
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="space-y-4 text-center">
          <div class="w-14 h-14 rounded bg-white border border-gold flex items-center justify-center text-gold mx-auto shadow-sm">
            <Hammer class="w-5 h-5" />
          </div>
          <div class="space-y-1">
            <h3 class="text-base font-bold text-walnut font-serif">03. Making Process</h3>
            <p class="text-xs text-wood leading-relaxed font-sans font-light">
              {lang === 'hi' ? 'सटीक नाप के अनुसार हैंड-सैंडेड निर्माण।' : 'Direct wood cutting, assembly, and joint polishing.'}
            </p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="space-y-4 text-center">
