---
import Layout from '../layouts/Layout.astro';
import { projectsData } from '../data/projects';
import { useTranslations } from '../data/translations';
import { MapPin, Play, Phone, MessageCircle, Folder, FileText } from '@lucide/astro';
import { CONTACT } from '@/config/contact';

interface Props {
  lang: 'en' | 'hi';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Available categories for filter buttons
const categories = [
  { id: 'all', label: t('gallery.filter.all') },
  { id: 'doors', label: t('gallery.filter.doors') },
  { id: 'wardrobes', label: t('gallery.filter.wardrobes') },
  { id: 'beds', label: lang === 'hi' ? 'बेड / पलंग' : 'Beds' },
  { id: 'cabinets', label: lang === 'hi' ? 'कैबिनेट व टीवी यूनिट' : 'Cabinets & TV Units' },
  { id: 'furniture', label: t('gallery.filter.furniture') },
  { id: 'cornice', label: t('gallery.filter.cornice') },
  { id: 'interiors', label: lang === 'hi' ? 'लकड़ी के इंटीरियर्स' : 'Wooden Interiors' }
];

const phoneNo = CONTACT.phone;
const whatsappLink = `https://wa.me/${CONTACT.whatsapp.replace('+', '')}?text=${encodeURIComponent(
  lang === 'hi'
    ? 'नमस्ते संतोष जी, मैंने आपके प्रोजेक्ट्स देखे और मुझे अपने घर के लिए भी ऐसा ही काम करवाना है।'
    : 'Hello Santosh Ji, I saw your completed projects and would like to discuss a custom design for my site.'
)}`;
---

<Layout
  title={lang === 'hi' ? 'हमारे कार्य और प्रोजेक्ट्स' : 'Our Completed Carpenter Projects in Patna'}
  description={lang === 'hi'
    ? 'संतोष शर्मा कारपेंटर (पटना फर्नीचर) द्वारा पटना के बोरिंग रोड, कंकड़बाग और बेली रोड में निर्मित अलमारी, सागवान दरवाजे और बाहरी कंक्रीट कॉर्निस।'
    : 'Explore wardrobes, custom teak wood beds, designer doors, and concrete architectural cornices completed by Santosh Sharma Carpenter in Patna.'}
  lang={lang}
  canonicalPath={lang === 'hi' ? '/hi/projects' : '/projects'}
>
  
  <!-- Page Header with subtle blueprint/drafting marks -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12 text-center space-y-3 border-b border-hairline relative">
    <!-- Architectural drafting marks -->
    <div class="absolute -bottom-1.5 left-8 w-3 h-3 border-b border-r border-gold/45"></div>
    <div class="absolute -bottom-1.5 right-8 w-3 h-3 border-b border-l border-gold/45"></div>
    
    <span class="font-mono eyebrow">04 / Portfolio</span>
    <h1 class="text-4xl sm:text-5xl font-serif font-medium tracking-tight text-walnut">
      {lang === 'hi' ? 'हमारे पूरे किए गए प्रोजेक्ट्स.' : 'Showcase of Completed Work.'}
    </h1>
    <p class="text-base text-wood max-w-2xl mx-auto font-sans font-light">
      {lang === 'hi'
        ? 'पटना के स्थानीय घरों और बंगलों में हमारे द्वारा तैयार किए गए कुछ बेहतरीन कस्टम फर्नीचर्स और शिल्पकला की तस्वीरें।'
        : 'A curated showcase of handcrafted woodwork, luxury wardrobes, Teak beds, and bungalow plastering mold designs finished in Patna.'}
    </p>
  </section>

  <!-- Filter Navigation Capsules -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="flex items-center justify-start md:justify-center overflow-x-auto gap-3 py-4 no-scrollbar scroll-smooth">
      {categories.map((cat, idx) => (
        <button
          class={`filter-btn px-5 py-2 rounded-full text-[10px] font-mono uppercase tracking-widest whitespace-nowrap border transition-all cursor-pointer ${
            idx === 0
              ? 'bg-walnut border-walnut text-[#FCFAF7] shadow-sm'
              : 'bg-white border-hairline text-wood hover:border-walnut'
          }`}
          data-category={cat.id}
        >
          {cat.label}
        </button>
      ))}
    </div>
  </section>

  <!-- Projects Presentation Slides -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="grid grid-cols-1 gap-12" id="projects-container">
      {projectsData.map((project, idx) => (
        <div
          class="project-card bg-white rounded-3xl overflow-hidden shadow-sm border border-hairline hover:border-gold/30 transition-all duration-500 grid grid-cols-1 lg:grid-cols-12 h-full opacity-1"
          data-category={project.category}
        >
          
          <!-- Left: Technical Meta Specifications Sheet -->
          <div class="lg:col-span-5 p-6 md:p-10 bg-canvas-soft flex flex-col justify-between border-b lg:border-b-0 lg:border-r border-hairline">
            <div class="space-y-6">
              <span class="font-mono text-[9px] uppercase tracking-widest text-gold font-bold block">
                TECHNICAL DATA SHEET // 0{idx + 1}
              </span>
              
              <div class="space-y-3 font-mono text-[11px] text-wood-dark/80">
                <div class="pb-2 border-b border-hairline">
                  <strong class="text-walnut block text-[9px] uppercase tracking-wider text-wood/40 mb-0.5">PROJECT BRAND</strong> 
                  <span class="text-xs font-serif font-bold text-walnut">{project.title[lang]}</span>
                </div>
                <div class="pb-2 border-b border-hairline">
                  <strong class="text-walnut block text-[9px] uppercase tracking-wider text-wood/40 mb-0.5">LOCATION SITE</strong>
                  <span>📍 {project.location[lang]}</span>
                </div>
                <div class="pb-2 border-b border-hairline">
                  <strong class="text-walnut block text-[9px] uppercase tracking-wider text-wood/40 mb-0.5">BUILD YEAR</strong>
                  <span>{project.year}</span>
                </div>
                <div class="pb-2">
                  <strong class="text-walnut block text-[9px] uppercase tracking-wider text-wood/40 mb-0.5">SPECIFICATION CLASS</strong>
                  <span class="uppercase text-gold">{project.category}</span>
                </div>
              </div>

              <!-- Description -->
              <div class="space-y-2">
                <span class="font-mono text-[9px] uppercase tracking-wider text-wood/40 block">PROJECT ANALYSIS</span>
                <p class="text-xs text-wood font-sans leading-relaxed font-light">
                  {project.description[lang]}
                </p>
              </div>
            </div>

            <!-- Footer Sheet Details -->
            <div class="pt-6 mt-8 border-t border-hairline flex items-center justify-between text-[10px] font-mono text-wood/50">
              <span class="flex items-center gap-1">
                <FileText class="w-3.5 h-3.5 text-gold" />
                <span>HAND CRAFTED LAYOUT</span>
              </span>
              <span class="text-gold font-bold">100% SECURE //</span>
            </div>
          </div>

          <!-- Right: Visual Media Showcase Frame -->
          <div class="lg:col-span-7 relative bg-black aspect-video lg:aspect-auto min-h-[300px] overflow-hidden group">
            {project.video ? (
              <video
                src={project.video}
                loop
                muted
                playsinline
                class="project-video-element w-full h-full object-cover"
                poster={project.image}
              />
              <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/50 transition-colors cursor-pointer video-play-overlay">
                <div class="w-14 h-14 rounded-full bg-white/95 border border-gold/30 flex items-center justify-center text-walnut shadow-lg transform group-hover:scale-105 transition-transform">
                  <Play class="w-6 h-6 fill-current translate-x-0.5 text-gold" />
                </div>
              </div>
            ) : (
              <img
                src={project.image}
                alt={project.title[lang]}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103"
              />
            )}
          </div>

        </div>
      ))}
    </div>
  </section>

  <!-- Final CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="bg-white border border-hairline rounded-[2.5rem] p-12 text-center space-y-6 max-w-4xl mx-auto shadow-sm">
      <h2 class="text-2xl sm:text-3xl font-serif font-bold text-walnut">
        {lang === 'hi' ? 'क्या आपको भी ऐसा ही कुछ बनवाना है?' : 'Want a similar custom woodwork for your home?'}
      </h2>
      <p class="text-sm sm:text-base text-wood max-w-2xl mx-auto font-sans font-light">
        {lang === 'hi'
          ? 'हमारे साथ अपनी डिज़ाइन साझा करें या मेरे पिताजी को अपने यहाँ बुलाएं। पटना के अंदर होम विजिट और साइट पर नाप लेना पूर्णतः निःशुल्क है।'
          : 'Share your dream design with us or invite my father for a visit. Site visits and quotation estimation anywhere inside Patna are completely free.'}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-2">
        <a href={`tel:${phoneNo}`} class="btn-primary w-full sm:w-auto">
          <Phone class="w-4 h-4 shrink-0 text-white" />
          <span>{lang === 'hi' ? 'कॉल करें' : 'Call Now'}</span>
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-secondary w-full sm:w-auto">
          <MessageCircle class="w-4 h-4 shrink-0 text-gold" />
          <span>{lang === 'hi' ? 'व्हाट्सएप चैट' : 'WhatsApp Chat'}</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  function initProjectsFilter() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.project-card');

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Toggle active button styling
        filterBtns.forEach((b) => {
          b.classList.remove('bg-walnut', 'border-walnut', 'text-[#FCFAF7]', 'shadow-sm');
          b.classList.add('bg-white', 'border-hairline', 'text-wood');
        });
        
        btn.classList.remove('bg-white', 'border-hairline', 'text-wood');
        btn.classList.add('bg-walnut', 'border-walnut', 'text-[#FCFAF7]', 'shadow-sm');

        const activeCategory = btn.getAttribute('data-category');

        // Filter cards with fade animation
        cards.forEach((card) => {
          const cardCategory = card.getAttribute('data-category');
          const element = card as HTMLElement;

          if (activeCategory === 'all' || cardCategory === activeCategory) {
            element.style.display = 'grid';
            setTimeout(() => {
              element.style.opacity = '1';
              element.style.transform = 'scale(1)';
            }, 50);
          } else {
            element.style.opacity = '0';
            element.style.transform = 'scale(0.98)';
            setTimeout(() => {
              element.style.display = 'none';
            }, 300);
          }
        });
      });
    });

    // Video play/pause on click triggers
    const videoOverlays = document.querySelectorAll('.video-play-overlay');
    videoOverlays.forEach((overlay) => {
      overlay.addEventListener('click', () => {
        const container = overlay.closest('.relative');
        const video = container?.querySelector('.project-video-element') as HTMLVideoElement;
        
        if (video) {
          if (video.paused) {
            video.play();
            overlay.classList.add('opacity-0');
            overlay.classList.add('pointer-events-none');
            video.controls = true;
          }
        }
      });
    });
  }

  // Bind events
  initProjectsFilter();
  document.addEventListener('astro:page-load', initProjectsFilter);
</script>
