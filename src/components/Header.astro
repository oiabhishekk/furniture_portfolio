---
import { useTranslations } from '../data/translations';
import { Menu, X, Globe, Hammer, Phone } from '@lucide/astro';
import { BUSINESS } from '@/config/business';
import { CONTACT } from '@/config/contact';
import { NAVIGATION } from '@/config/navigation';

interface Props {
  lang: 'en' | 'hi';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

// Localized URL switcher
function getLocalizedUrl(targetLang: 'en' | 'hi') {
  const cleanPath = currentPath.replace(/\/$/, '') || '/';
  
  if (targetLang === 'hi') {
    if (cleanPath.startsWith('/hi')) {
      return cleanPath;
    }
    return cleanPath === '/' ? '/hi' : `/hi${cleanPath}`;
  } else {
    if (cleanPath.startsWith('/hi')) {
      const subpath = cleanPath.slice(3); // remove "/hi"
      return subpath === '' ? '/' : subpath;
    }
    return cleanPath;
  }
}

const localizedNav = (path: string) => {
  if (lang === 'hi') {
    return path === '/' ? '/hi' : `/hi${path}`;
  }
  return path;
};

const navItems = NAVIGATION.map((item) => ({
  label: item.label[lang],
  url: localizedNav(item.path)
}));

const phoneNo = CONTACT.phone;

// Check if active page
const isLinkActive = (itemUrl: string) => {
  const cleanPath = currentPath.replace(/\/$/, '');
  const cleanItemUrl = itemUrl.replace(/\/$/, '');
  if (cleanItemUrl === '' || cleanItemUrl === '/hi') {
    return cleanPath === '' || cleanPath === '/hi';
  }
  return cleanPath === cleanItemUrl;
};
---

<header
  id="main-nav-header"
  class="fixed top-0 left-0 right-0 z-50 bg-[#FCFAF7]/80 border-b border-transparent backdrop-blur-md transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      
      <!-- Brand Logo / Name (Walnut & Gold) -->
      <a href={lang === 'hi' ? '/hi' : '/'} class="flex items-center space-x-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-walnut flex items-center justify-center shadow group-hover:scale-105 transition-transform shrink-0">
          <Hammer class="w-4 h-4 text-gold" />
        </div>
        <div class="flex flex-col">
          <span class="text-base font-serif font-black tracking-tight text-walnut leading-none">
            {BUSINESS.logo.text[lang]}
          </span>
          <span class="text-[8px] uppercase tracking-widest text-gold mt-0.5 leading-none font-mono">
            {BUSINESS.logo.subtext[lang]}
          </span>
        </div>
      </a>

      <!-- Desktop Nav Menu (Space Grotesk typography) -->
      <nav class="hidden md:flex items-center space-x-1">
        {navItems.map((item) => {
          const active = isLinkActive(item.url);
          return (
            <a
              href={item.url}
              class={`text-[10px] font-serif uppercase tracking-widest px-3.5 py-1.5 rounded-lg transition-all relative ${
                active
                  ? 'text-walnut font-bold bg-canvas-soft-2'
                  : 'text-wood hover:text-walnut hover:bg-canvas-soft-2/50'
              }`}
            >
              {item.label}
              {active && (
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-gold"></span>
              )}
            </a>
          );
        })}
      </nav>

      <!-- Right Side Actions (Language Switcher, Call Button) -->
      <div class="hidden md:flex items-center space-x-4">
        
        <!-- Language Switcher -->
        <div class="flex items-center border border-hairline rounded-md p-0.5 bg-canvas-soft-2 shadow-inner">
          <a
            href={getLocalizedUrl('en')}
            class={`px-2 py-0.5 text-[9px] font-mono font-bold rounded transition-all ${
              lang === 'en'
                ? 'bg-walnut text-[#FCFAF7] shadow-sm'
                : 'text-wood hover:text-walnut'
            }`}
          >
            EN
          </a>
          <a
            href={getLocalizedUrl('hi')}
            class={`px-2 py-0.5 text-[9px] font-mono font-bold rounded transition-all ${
              lang === 'hi'
                ? 'bg-walnut text-[#FCFAF7] shadow-sm'
                : 'text-wood hover:text-walnut'
            }`}
          >
            हिन्दी
          </a>
        </div>

        <!-- Phone Call Button (Stark 6px, height 32px) -->
        <a
          href={`tel:${phoneNo}`}
          class="btn-nav-primary"
        >
          <Phone class="w-3 h-3 text-white" />
          <span>{t('hero.cta.call')}</span>
        </a>

      </div>

      <!-- Mobile Controls (Language + Hamburger) -->
      <div class="flex items-center space-x-2 md:hidden">
        <!-- Mobile Language Selector -->
        <a
          href={getLocalizedUrl(lang === 'en' ? 'hi' : 'en')}
          class="flex items-center space-x-1 border border-hairline rounded-md px-2.5 h-8 text-[10px] font-mono font-bold bg-white/50"
        >
          <Globe class="w-3.5 h-3.5 text-gold" />
          <span>{lang === 'en' ? 'हिन्दी' : 'EN'}</span>
        </a>

        <!-- Hamburger menu -->
        <button
          id="mobile-menu-btn"
          class="p-1.5 rounded-md border border-hairline bg-white/50 text-walnut"
          aria-expanded="false"
          aria-label="Toggle menu"
        >
          <Menu class="w-5 h-5 block" id="menu-icon" />
          <X class="w-5 h-5 hidden" id="close-icon" />
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Overlay Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute top-full left-0 right-0 bg-[#FCFAF7]/95 border-b border-hairline py-6 px-6 space-y-4 shadow-xl transition-all duration-300 transform scale-y-95 origin-top"
  >
    <div class="flex flex-col space-y-2">
      {navItems.map((item) => (
        <a
          href={item.url}
          class="text-sm font-semibold py-2 px-3 rounded-lg hover:bg-canvas-soft-2 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  // Mobile menu control
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  if (mobileMenuBtn && mobileMenu && menuIcon && closeIcon) {
    mobileMenuBtn.addEventListener('click', () => {
      const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
      mobileMenuBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      
      mobileMenu.classList.toggle('hidden');
      menuIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });
  }

  // Glass scroll effect listener
  const header = document.getElementById('main-nav-header');
  const handleScroll = () => {
    if (window.scrollY > 15) {
      header?.classList.add('shadow-md', 'bg-[#FCFAF7]/95', 'border-hairline');
      header?.classList.remove('bg-[#FCFAF7]/80', 'border-transparent');
    } else {
      header?.classList.remove('shadow-md', 'bg-[#FCFAF7]/95', 'border-hairline');
      header?.classList.add('bg-[#FCFAF7]/80', 'border-transparent');
    }
  };

  window.addEventListener('scroll', handleScroll);
  document.addEventListener('astro:page-load', () => {
    window.removeEventListener('scroll', handleScroll);
    window.addEventListener('scroll', handleScroll);
  });
</script>
