---
import Layout from '../../layouts/Layout.astro';
import { servicesData } from '@/config/services';
import { projectsData } from '../../data/projects';
import { useTranslations } from '../../data/translations';
import { Phone, MessageCircle, ArrowRight, ShieldCheck, MapPin, ChevronRight, Hammer } from '@lucide/astro';
import { CONTACT } from '@/config/contact';

export function getStaticPaths() {
  return Object.keys(servicesData).map((slug) => ({
    params: { slug },
    props: {
      service: servicesData[slug].en,
      slug
    },
  }));
}

const { service, slug } = Astro.props;
const t = useTranslations('en');

// Find related projects by matching category or slug
const relatedProjects = projectsData.filter((p) => p.category === slug || (slug === 'furniture' && p.category === 'furniture'));

const phoneNo = CONTACT.phone;
const whatsappLink = `https://wa.me/${CONTACT.whatsapp.replace('+', '')}?text=${encodeURIComponent(
  `Hello Santosh Ji, I am looking for your custom "${service.title}" services in Patna. Please let me know when you can visit for measurements.`
)}`;

const canonicalPath = `/services/${slug}`;
---

<Layout
  title={`${service.metaTitle}`}
  description={service.metaDesc}
  lang="en"
  canonicalPath={canonicalPath}
>
  
  <!-- BREADCRUMBS -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
    <nav class="flex items-center space-x-2 text-xs font-semibold text-wood-dark/50 dark:text-beige-light/50">
      <a href="/" class="hover:text-primary dark:hover:text-gold transition-colors">Home</a>
      <ChevronRight class="w-3.5 h-3.5 shrink-0" />
      <span class="text-wood-dark/40 dark:text-beige-light/40">Services</span>
      <ChevronRight class="w-3.5 h-3.5 shrink-0" />
      <span class="text-primary dark:text-gold font-bold">{service.title}</span>
    </nav>
  </div>

  <!-- SERVICE DETAILS HEADER SECTION with blueprint lines -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 border-b border-hairline relative">
    <div class="absolute -bottom-1.5 left-8 w-3 h-3 border-b border-r border-gold/45"></div>
    <div class="absolute -bottom-1.5 right-8 w-3 h-3 border-b border-l border-gold/45"></div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      
      <!-- Content Details -->
      <div class="space-y-8">
        <div class="space-y-4">
          <span class="text-xs uppercase font-extrabold tracking-widest text-primary dark:text-gold block">
            Custom Carpentry Specialization
          </span>
          <h1 class="text-3xl sm:text-5xl font-black tracking-tight leading-tight text-wood-dark dark:text-white">
            {service.title}
          </h1>
          <p class="text-base sm:text-lg leading-relaxed text-wood-dark/80 dark:text-beige-light/80 pt-2">
            {service.description}
          </p>
        </div>

        <!-- Subservices Detailed Checkboxes -->
        <div class="bg-beige-dark/20 dark:bg-wood-dark/30 rounded-3xl p-6 md:p-8 border border-secondary/5 dark:border-gold/5 space-y-4">
          <h3 class="text-lg font-bold tracking-tight">{service.title} Sub-categories:</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {service.subservices.map((sub) => (
              <div class="flex items-center space-x-3 text-sm font-medium">
                <ShieldCheck class="w-5 h-5 text-gold shrink-0" />
                <span>{sub}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Call to Action Buttons -->
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a
            href={`tel:${phoneNo}`}
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary hover:bg-secondary text-white font-bold py-4 px-8 rounded-2xl shadow-xl transition-all"
          >
            <Phone class="w-5 h-5" />
            <span>Call for Site Visit</span>
          </a>
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-4 px-8 rounded-2xl shadow-xl transition-all"
          >
            <MessageCircle class="w-5 h-5" />
            <span>WhatsApp details</span>
          </a>
        </div>

      </div>

      <!-- Feature Card Showcase with real references image -->
      <div class="space-y-8">
        <div class="glass rounded-3xl overflow-hidden shadow-2xl border border-secondary/15 dark:border-gold/15 p-4 bg-white/40">
          <img
            src={service.image}
            alt={service.title}
            class="w-full h-[350px] object-cover rounded-2xl shadow-inner"
          />
        </div>

        <!-- Service-Specific Features -->
        <div class="glass rounded-3xl p-8 space-y-4 border border-secondary/10 dark:border-gold/10">
          <h3 class="text-lg font-bold tracking-tight text-wood-dark dark:text-white">Why Choose Our {service.title}?</h3>
          <ul class="space-y-3">
            {service.features.map((feature) => (
              <li class="flex items-start space-x-3 text-sm text-wood-dark/70 dark:text-beige-light/70">
                <span class="w-2 h-2 rounded-full bg-gold shrink-0 mt-1.5"></span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- RELATED PROJECTS SHOWCASE -->
  {relatedProjects.length > 0 && (
    <section class="border-t border-secondary/10 dark:border-gold/10 bg-beige-dark/10 dark:bg-wood-dark/10 py-20 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-10 text-center">
          Our Completed {service.title} Projects in Patna
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedProjects.map((project) => (
            <div class="glass rounded-2xl overflow-hidden border border-secondary/10 dark:border-gold/10 flex flex-col h-full hover:shadow-xl transition-all duration-300">
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={project.image}
                  alt={project.title.en}
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6 space-y-3 flex-grow flex flex-col justify-between">
                <div class="space-y-2">
                  <h3 class="text-lg font-bold text-wood-dark dark:text-white">{project.title.en}</h3>
                  <p class="text-xs text-wood-dark/60 dark:text-beige-light/60 leading-relaxed line-clamp-2">
                    {project.description.en}
                  </p>
                </div>
                <div class="pt-4 border-t border-secondary/10 dark:border-gold/10 text-xs text-wood-dark/50 dark:text-beige-light/50 flex items-center justify-between">
                  <span>📍 {project.location.en}</span>
                  <span>{project.year}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- VISIT INQUIRY / CONVERSION BANNER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="glass border border-secondary/10 dark:border-gold/15 rounded-3xl p-8 md:p-12 bg-white/40 flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left">
      <div class="space-y-3 max-w-2xl">
        <h3 class="text-xl sm:text-2xl font-bold tracking-tight">Need a custom measurement for {service.title}?</h3>
        <p class="text-sm text-wood-dark/70 dark:text-beige-light/70">
          Book a site visit today. My father Santosh Sharma will visit your flat or bungalow in Patna to take precise details and discuss customized choices.
        </p>
      </div>
      <a
        href={`tel:${phoneNo}`}
        class="inline-flex items-center gap-2.5 bg-primary hover:bg-secondary text-white font-bold py-4 px-6 rounded-2xl shadow-xl transition-all whitespace-nowrap active:scale-95"
      >
        <Phone class="w-4 h-4" />
        <span>Request Site Visit</span>
      </a>
    </div>
  </section>

</Layout>
